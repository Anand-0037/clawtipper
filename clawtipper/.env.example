# =============================================================================
# ClawTipper agent (Node.js) — copy to .env — NOT run on Vercel by default
# =============================================================================
# This process is long-running (auto-runner, Telegram). Host on Render, Railway,
# Fly.io, a small VPS, or run locally. Vercel only hosts the Next.js site.
# =============================================================================

# Required: BIP-39 mnemonic — from clawtipper/: node scripts/generate-mnemonic.js
MNEMONIC=your twelve word mnemonic phrase here for wallet

# Required: Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Strongly recommended: avoids GitHub API rate limits
GITHUB_TOKEN=

# Chain — RPC and USDT must be the same network
CHAIN=polygon
PROVIDER_URL=https://polygon.drpc.org
USDT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F

# Optional gas cap (wei) for wdk-wallet-evm
# WDK_TRANSFER_MAX_FEE_WEI=100000000000000

# Transfer: retry RPC errors before hash; then wait for receipt
# WDK_TX_MAX_RETRIES=3
# WDK_TX_RETRY_DELAY_MS=1500
# WDK_TX_CONFIRM_POLL_MS=3000
# WDK_TX_CONFIRM_TIMEOUT_MS=120000

# Budget guardrails
MIN_WALLET_BALANCE_USDT=10
MAX_TIP_USDT=3
MIN_TIP_USDT=0.5
MAX_DAILY_PERCENT=5
MIN_ROI_SCORE=1.5
MIN_LINES_CHANGE=5
FEE_PERCENT=10
PLATFORM_WALLET_ADDRESS=

# auto-runner.js only
WATCH_REPOS=octocat/Hello-World,owner/repo2
POLL_INTERVAL_MS=60000

# Optional control plane
TELEGRAM_BOT_TOKEN=
