# ClawTipper / GitReward Agent - Environment Configuration
# Copy to .env and fill in your values

# Required: BIP-39 mnemonic (12 or 24 words) - generate with: node -e "const WDK=require('@tetherto/wdk');console.log(WDK.getRandomSeedPhrase())"
MNEMONIC=your twelve word mnemonic phrase here for wallet

# Required: Gemini API key for LLM evaluation - get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Optional: GitHub token for higher rate limits (unauthenticated = 60/hr)
# Get from https://github.com/settings/tokens
GITHUB_TOKEN=

# Chain config — RPC and USDT contract MUST be same network
# Polygon mainnet (default; real USDT tips):
CHAIN=polygon
PROVIDER_URL=https://polygon.drpc.org

# USDT contract (must match network!)
# Polygon mainnet: 0xc2132D05D31c914a87C6611C10748AEb04B58e8F
# Polygon Amoy: ask Discord for test token address
# Amoy testnet (only if you use Amoy USDT — NOT mainnet address below):
# PROVIDER_URL=https://polygon-amoy.drpc.org
# USDT_ADDRESS=<amoy-test-usdt-from-tether-discord>
USDT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F

# Optional: cap gas for transfers (wei), see wdk-wallet-evm README
# WDK_TRANSFER_MAX_FEE_WEI=100000000000000

# Budget guardrails (economic soundness)
MIN_WALLET_BALANCE_USDT=10
MAX_TIP_USDT=3
MIN_TIP_USDT=0.5
MAX_DAILY_PERCENT=5
MIN_ROI_SCORE=1.5
MIN_LINES_CHANGE=5
FEE_PERCENT=10
PLATFORM_WALLET_ADDRESS=

# Autonomous agent (auto-runner.js)
WATCH_REPOS=octocat/Hello-World,owner/repo2
POLL_INTERVAL_MS=60000

# Telegram bot - get token from @BotFather
TELEGRAM_BOT_TOKEN=
