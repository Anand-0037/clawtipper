# Public site URL for metadata / OG (production)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Repo link for "View GitHub" CTA
NEXT_PUBLIC_GITHUB_REPO=https://github.com/your-org/clawtipper

# Optional: host your agent's transactions.json (raw array or { "entries": [...] }) anywhere public
# Example: GitHub gist raw URL, S3, or a tiny serverless JSON endpoint
ACTIVITY_SOURCE_URL=

# Default: NO fake activity — only ACTIVITY_SOURCE_URL or sibling clawtipper/logs.
# Opt-in demo seed + UI simulation (local only):
# ALLOW_ACTIVITY_DEMO=true
# Legacy alias: STRICT_REAL_FEED=false also enables demo fallback

# WDK Indexer (on-chain read / verification — not your app database)
# Get API key from Tether WDK / developer portal. Agent wallet = same 0x you derive from MNEMONIC.
WDK_INDEXER_BASE_URL=https://wdk-api.tether.io
WDK_INDEXER_API_KEY=
AGENT_WALLET_ADDRESS=
# Optional overrides (defaults: polygon, usdt)
# WDK_INDEXER_CHAIN=polygon
# WDK_INDEXER_TOKEN=usdt
# Alias if you prefer:
# INDEXER_WALLET_ADDRESS=
