# =============================================================================
# ClawTipper Web (Next.js) — copy to .env.local for local dev, or set in Vercel
# =============================================================================
# Vercel: Project → Settings → Environment Variables (Production + Preview).
# Do not commit real API keys. NEXT_PUBLIC_* are exposed to the browser.
# =============================================================================

# --- Public (safe to expose) ---
# Local dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# After first deploy, set Production to: https://<your-project>.vercel.app
NEXT_PUBLIC_GITHUB_REPO=https://github.com/Anand-0037/clawtipper

# --- Activity feed (required for real data on Vercel) ---
# Host raw JSON (array of tx rows or wrapper your parser accepts). Examples:
# - GitHub Gist → Raw URL
# - Public S3 / R2 / blob URL
# - Any HTTPS URL returning the same shape as clawtipper/logs/transactions.json
# On Vercel, ../clawtipper/logs is NOT available — you must set this in production.
ACTIVITY_SOURCE_URL=

# --- Judge / production mode ---
# Leave unset on Vercel = real-only API (no seeded demo, no client simulation).
# Local marketing only:
# ALLOW_ACTIVITY_DEMO=true

# --- WDK Indexer (optional, recommended for “on-chain proof” card) ---
# Same agent wallet 0x you use with the Node agent (from MNEMONIC index 0).
WDK_INDEXER_BASE_URL=https://wdk-api.tether.io
WDK_INDEXER_API_KEY=
AGENT_WALLET_ADDRESS=
# WDK_INDEXER_CHAIN=polygon
# WDK_INDEXER_TOKEN=usdt
# INDEXER_WALLET_ADDRESS=

# Legacy alias for strict demo flag (prefer ALLOW_ACTIVITY_DEMO above):
# STRICT_REAL_FEED=true
